{
    "name": "textanalysistoolpro",
    "displayName": "TextAnalysisToolPro",
    "description": "A VS code extension inspired by TextAnalysisTool.NET",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "textanalysistoolpro",
                    "title": "TextAnalysisToolPro",
                    "icon": "$(filter)"
                }
            ]
        },
        "views": {
            "textanalysistoolpro": [
                {
                    "id": "filtersView",
                    "name": "Filters",
                    "icon": "$(filter)"
                }
            ]
        },
        "commands": [
            {
                "command": "textanalysistoolpro.addFilter",
                "title": "Add Filter",
                "icon": "$(add)"
            },
            {
                "command": "textanalysistoolpro.removeFilter",
                "title": "Remove Filter",
                "icon": "$(trash)"
            },
            {
                "command": "textanalysistoolpro.toggleFilter",
                "title": "Toggle Filter Enable"
            },
            {
                "command": "textanalysistoolpro.editFilter",
                "title": "Edit Filter",
                "icon": "$(edit)"
            },
            {
                "command": "textanalysistoolpro.showFiltered",
                "title": "Show Only Filtered Lines",
                "icon": "$(eye)"
            },
            {
                "command": "textanalysistoolpro.importFilters",
                "title": "Import Filters",
                "icon": "$(file-symlink-file)"
            },
            {
                "command": "textanalysistoolpro.exportFilters",
                "title": "Export Filters",
                "icon": "$(save-all)"
            }
        ],
        "keybindings": [
            {
                "command": "textanalysistoolpro.showFiltered",
                "key": "ctrl+h",
                "mac": "cmd+h",
                "when": "editorTextFocus"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "textanalysistoolpro.addFilter",
                    "when": "view == filtersView",
                    "group": "navigation@1"
                },
                {
                    "command": "textanalysistoolpro.showFiltered",
                    "when": "view == filtersView",
                    "group": "navigation@2"
                },
                {
                    "command": "textanalysistoolpro.importFilters",
                    "when": "view == filtersView",
                    "group": "navigation@3"
                },
                {
                    "command": "textanalysistoolpro.exportFilters",
                    "when": "view == filtersView",
                    "group": "navigation@4"
                }
            ],
            "view/item/context": [
                {
                    "command": "textanalysistoolpro.toggleFilter",
                    "when": "view == filtersView"
                },
                {
                    "command": "textanalysistoolpro.removeFilter",
                    "when": "view == filtersView"
                },
                {
                    "command": "textanalysistoolpro.editFilter",
                    "when": "view == filtersView"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/mocha": "^10.0.1",
        "@types/node": "18.x",
        "@typescript-eslint/eslint-plugin": "^5.59.8",
        "@typescript-eslint/parser": "^5.59.8",
        "eslint": "^8.41.0",
        "glob": "^8.1.0",
        "mocha": "^10.2.0",
        "typescript": "^5.1.3",
        "@vscode/test-electron": "^2.3.2"
    }
}