{
    "name": "textanalysistoolpro",
    "displayName": "TextAnalysisToolPro",
    "description": "A VS code extension inspired by TextAnalysisTool.NET",
    "version": "0.2.0",
    "publisher": "RohitHill",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "configuration": {
            "title": "TextAnalysisToolPro",
            "properties": {
                "textanalysistoolpro.defaultForegroundColor": {
                    "type": "string",
                    "default": "#ffffff",
                    "description": "Default foreground color for new filters."
                },
                "textanalysistoolpro.defaultBackgroundColor": {
                    "type": "string",
                    "default": "#44475a",
                    "description": "Default background color for new filters."
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "textanalysistoolpro",
                    "title": "TextAnalysisToolPro",
                    "icon": "$(filter)"
                }
            ]
        },
        "views": {
            "textanalysistoolpro": [
                {
                    "id": "filtersView",
                    "name": "Filters",
                    "type": "webview",
                    "icon": "$(filter)"
                },
                {
                    "id": "filterEditorView",
                    "name": "Filter Editor",
                    "type": "webview",
                    "icon": "$(edit)"
                }
            ]
        },
        "commands": [
            {
                "command": "textanalysistoolpro.addFilter",
                "title": "Add Filter",
                "icon": "$(add)"
            },
            {
                "command": "textanalysistoolpro.removeFilter",
                "title": "Remove Filter",
                "icon": "$(trash)"
            },
            {
                "command": "textanalysistoolpro.toggleFilter",
                "title": "Toggle Filter Enable"
            },
            {
                "command": "textanalysistoolpro.editFilter",
                "title": "Edit Filter",
                "icon": "$(edit)"
            },
            {
                "command": "textanalysistoolpro.showFiltered",
                "title": "Open File for Analysis",
                "icon": "$(root-folder-opened)"
            },
            {
                "command": "textanalysistoolpro.importFilters",
                "title": "Import Filters",
                "icon": "$(file-directory-create)"
            },
            {
                "command": "textanalysistoolpro.exportFilters",
                "title": "Export Filters",
                "icon": "$(save-all)"
            },
            {
                "command": "textanalysistoolpro.toggleFilterActivation",
                "title": "Toggle Filter Activation"
            },
            {
                "command": "textanalysistoolpro.goToNextMatch",
                "title": "Go To Next Match"
            },
            {
                "command": "textanalysistoolpro.goToPreviousMatch",
                "title": "Go To Previous Match"
            },
            {
                "command": "textanalysistoolpro.analyzeCurrentFile",
                "title": "Analyze Current File",
                "icon": "$(file-code)"
            },
            {
                "command": "textanalysistoolpro.removeAllFilters",
                "title": "Remove All Filters",
                "icon": "$(clear-all)"
            },
            {
                "command": "textanalysistoolpro.createGroup",
                "title": "New Filter Group",
                "icon": "$(new-folder)"
            },
            {
                "command": "textanalysistoolpro.cloneGroup",
                "title": "Clone Filter Group",
                "icon": "$(copy)"
            },
            {
                "command": "textanalysistoolpro.renameGroup",
                "title": "Rename Filter Group",
                "icon": "$(edit)"
            },
            {
                "command": "textanalysistoolpro.deleteGroup",
                "title": "Delete Filter Group",
                "icon": "$(trash)"
            }
        ],
        "keybindings": [
            {
                "command": "textanalysistoolpro.toggleFilterActivation",
                "key": "ctrl+h",
                "mac": "cmd+h",
                "when": "editorTextFocus"
            },
            {
                "command": "textanalysistoolpro.goToNextMatch",
                "key": "a",
                "args": "a",
                "when": "resourceScheme == 'textanalysistoolpro' && editorTextFocus"
            },
            {
                "command": "textanalysistoolpro.goToPreviousMatch",
                "key": "shift+a",
                "args": "a",
                "when": "resourceScheme == 'textanalysistoolpro' && editorTextFocus"
            },
            {
                "command": "textanalysistoolpro.goToNextMatch",
                "key": "b",
                "args": "b",
                "when": "resourceScheme == 'textanalysistoolpro' && editorTextFocus"
            },
            {
                "command": "textanalysistoolpro.goToPreviousMatch",
                "key": "shift+b",
                "args": "b",
                "when": "resourceScheme == 'textanalysistoolpro' && editorTextFocus"
            },
            {
                "command": "textanalysistoolpro.goToNextMatch",
                "key": "c",
